{
  "name": "contract-storage-demo",
  "version": "1.0.0",
  "description": "Demo of storing data in contract storage on Ethereum",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "node": "hardhat node",
    "demo": "hardhat run scripts/demo.js --network localhost",
    "deploy": "hardhat run scripts/deploy.js --network localhost",
    "deploy:arc": "hardhat run scripts/deploy.js --network 'arc-testnet'",
    "store": "hardhat run scripts/store.js --network localhost",
    "store:arc": "hardhat run scripts/store.js --network 'arc-testnet'",
    "retrieve": "hardhat run scripts/retrieve.js --network localhost",
    "retrieve:arc": "hardhat run scripts/retrieve.js --network 'arc-testnet'"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "dotenv": "^17.2.3",
    "hardhat": "^2.19.0"
  },
  "dependencies": {
    "ethers": "^6.9.0"
  }
}
